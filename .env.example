NEXT_PUBLIC_API_URL=https://test.com
NEXT_PUBLIC_PYTHON_API_URL=https://test-python-api.com
NEXT_PUBLIC_APP_URL=https://test-ui.com
NEXTAUTH_URL=https://test.com
NEXTAUTH_SECRET=your-nextauth-secret-here

# Option A: static token (paste from Postman login, must manually refresh when expired)
# INTEGRATION_SERVICE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..........

# Integration gateway — dedicated machine account (role: integration_service)
# Option B: service account (auto-refreshes — RECOMMENDED)
INTEGRATION_SERVICE_USER=service-account-username-here
INTEGRATION_SERVICE_PASS=service-account-password-here

# Use whichever var name your project already uses
DATABASE_URL=postgresql://user:pass@localhost:5432/kyc_db